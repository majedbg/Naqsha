# Supabase (from supabase.com dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# App URL (used for OAuth redirect and share links)
VITE_APP_URL=http://localhost:5173

# Anthropic API Key (set as Supabase secret, NOT as VITE_ env var)
# Deploy the edge function: supabase functions deploy generate-pattern
# Set the secret: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
